{
  "name": "deck.gl-raster-multiband",
  "version": "1.0.0",
  "description": "A JavaScript plugin that enables GPU-accelerated multiband raster algebra and styling for deck.gl-raster",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/deck.gl-raster-multiband.cjs.js",
  "module": "./dist/deck.gl-raster-multiband.es.js",
  "unpkg": "./dist/deck.gl-raster-multiband.umd.js",
  "jsdelivr": "./dist/deck.gl-raster-multiband.umd.js",
  "exports": {
    ".": {
      "import": "./dist/deck.gl-raster-multiband.es.js",
      "require": "./dist/deck.gl-raster-multiband.cjs.js",
      "default": "./dist/deck.gl-raster-multiband.es.js"
    },
    "./umd": "./dist/deck.gl-raster-multiband.umd.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "submodules": "git submodule update --init --recursive",
    "install:gpu": "CC=gcc-11 CXX=g++-11 pnpm install gpu.js",
    "setup": "pnpm run submodules && pnpm install && pnpm run install:gpu",
    "dev": "vite",
    "build:lib": "BUILD_MODE=library vite build",
    "build:example:local": "vite build --base / --outDir dist-local",
    "build:example:deploy": "vite build --base /deckglraster-multiband/ --outDir dist-deploy",
    "build": "pnpm run build:lib",
    "build:all": "pnpm run build:lib && pnpm run build:example:deploy",
    "build:docs": "jsdoc -c scripts/jsdoc.json && node scripts/customize-jsdoc.mjs",
    "release": "pnpm run build:all && pnpm run build:docs",
    "deploy": "bash scripts/deploy.sh",
    "preview": "vite preview",
    "publish": "bash scripts/publish.sh"
  },
  "keywords": [
    "deck.gl",
    "raster",
    "multiband",
    "geotiff",
    "gpu",
    "webgl",
    "geospatial",
    "sentinel-2",
    "ndvi"
  ],
  "author": "Abel Vázquez Montoro",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "gpu.js": "^2.16.0",
    "proj4": ">=2.20.4"
  },
  "peerDependencies": {
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/geo-layers": "^9.2.11",
    "@deck.gl/mapbox": "^9.2.11"
  },
  "devDependencies": {
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/extensions": "^9.2.11",
    "@deck.gl/geo-layers": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "jsdoc": "^4.0.4",
    "@deck.gl/mapbox": "^9.2.11",
    "puppeteer-core": "^24.38.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:AbelVM/deckglraster-multiband.git"
  }
}
